{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/**.js": {
      "runtime": "nodejs20.x",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "env": {
    "MONGODB_URI": "@MONGODB_URI",
    "DB_NAME": "@DB_NAME"
  }
}
